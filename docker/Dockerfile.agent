FROM debian:bookworm-slim

# Install dependencies required by the installation script and NATS (for tests if needed)
RUN apt-get update && apt-get install -y \
    ca-certificates \
    curl \
    jq \
    && rm -rf /var/lib/apt/lists/*

# Set the environment variable for the install directory
ENV INSTALL_DIR=/usr/local/bin
ENV PATH="/usr/local/bin:${PATH}"

# Create autonomic workspace directory
RUN mkdir -p /root/.autonomic && chmod 777 /root/.autonomic

# Run the installation script to download all release binaries
RUN curl -fsSL https://raw.githubusercontent.com/autonomic-ai-dev/agent-body/master/scripts/install-all-organs.sh | bash

# Expose generic ports used by the daemons
EXPOSE 3100 3101 3102 3103 3104 3105 3106

# The command is overridden by docker-compose for each specific daemon
ENTRYPOINT ["sh", "-c", "exec $0 \"$@\""]
CMD ["autonomic", "--help"]
